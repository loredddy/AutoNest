# ═══════════════════════════════════════
# AUTONEST — ENVIRONMENT VARIABLES
# Copy to .env for local dev
# NEVER commit .env to git
# ═══════════════════════════════════════

# Groq API key — used by Vercel function in production
# Get free key at: https://console.groq.com
# Add this in Vercel dashboard, NOT here
GROQ_API_KEY=your_groq_key_here

# Google API key — YouTube feed
# Get at: https://console.cloud.google.com
REACT_APP_GOOGLE_API_KEY=your_google_key_here
